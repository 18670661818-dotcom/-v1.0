# ==================== 生产环境配置 ====================
# 应用环境
APP_ENV=prod

# ==================== 数据库配置 ====================
# PostgreSQL数据库（生产环境）
DATABASE_URL=postgresql://kitchen_user:kitchen_password@postgres:5432/kitchen_ai

# PostgreSQL连接参数（可选）
# DATABASE_URL=postgresql://kitchen_user:kitchen_password@postgres:5432/kitchen_ai?connect_timeout=10&application_name=kitchen_ai

# ==================== 安全配置 ====================
# JWT密钥（生产环境必须修改为随机字符串）
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=please-change-this-secret-key-to-random-string

# Token过期时间：8小时（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ==================== 模型配置 ====================
# YOLO模型路径（Docker容器内路径）
MODEL_PATH=/app/models/best.pt

# 推理置信度阈值
CONF_THRESHOLD=0.4

# NMS IoU阈值
IOU_THRESHOLD=0.45

# 推理设备：生产环境建议使用GPU
DEVICE=cuda:0

# ==================== 推理引擎配置 ====================
# 检测帧率：3 FPS
DETECTION_FPS=3

# 批处理大小（根据GPU内存调整）
BATCH_SIZE=16

# 采样间隔（秒）
SAMPLE_INTERVAL=2.0

# ==================== 告警配置 ====================
# 告警冷却时间：30秒
ALERT_COOLDOWN_SECONDS=30

# 每小时最大告警数
MAX_ALERTS_PER_HOUR=100

# ==================== 服务器配置 ====================
# 服务器主机
SERVER_HOST=0.0.0.0

# 服务器端口
SERVER_PORT=8000

# 调试模式：生产环境关闭
DEBUG=false

# ==================== CORS配置 ====================
# 允许的前端地址（生产环境填写实际域名）
ALLOWED_ORIGINS=https://kitchen-ai.example.com,https://admin.kitchen-ai.example.com

# ==================== 存储配置 ====================
# 告警图片存储目录（Docker卷挂载）
ALERT_IMAGE_DIR=/app/storage/alerts

# 日志存储目录
LOG_DIR=/app/storage/logs

# ==================== WebSocket配置 ====================
# WebSocket心跳间隔：30秒
WS_HEARTBEAT_INTERVAL=30

